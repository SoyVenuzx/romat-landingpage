---
import { Image } from 'astro:assets';
import { Facebook, Instagram, Mail, MessageCircle } from 'lucide-react';
import clinicLogo from '../../assets/branding/logoclinica.png';
import { clinicBusinessData } from '../../utils/seo';

const quickLinks = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Laboratorio', href: '#laboratorio' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];

const services = [
  'Medicina Interna',
  'Chequeo ocupacional',
  'Cardiología',
  'Laboratorio',
  'Pediatría',
];
const whatsappLink = `https://wa.me/${clinicBusinessData.whatsappNumber.replace(/\D/g, '')}`;
---

<footer class="bg-navy text-navy-foreground">
  <div class="container mx-auto px-4 py-16 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="mb-4 flex items-center gap-3">
          <Image
            src={clinicLogo}
            alt="Logo principal de Servicios Médicos ROMAT"
            format="webp"
            width={64}
            height={64}
            loading="lazy"
            class="h-12 w-12 rounded-xl bg-white/95 p-1"
          />
          <span class="text-lg font-extrabold">ROMAT</span>
        </div>
        <p class="text-sm leading-relaxed text-navy-foreground/70">
          Servicios Médicos ROMAT - Tu clínica de confianza para el cuidado
          integral de la salud.
        </p>
      </div>

      <div>
        <h4
          class="mb-4 text-sm font-bold uppercase tracking-wider text-navy-foreground/50"
        >
          Enlaces
        </h4>
        <ul class="space-y-2 text-sm">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-navy-foreground/70 transition-colors hover:text-accent"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4
          class="mb-4 text-sm font-bold uppercase tracking-wider text-navy-foreground/50"
        >
          Servicios
        </h4>
        <ul class="space-y-2 text-sm">
          {
            services.map((service) => (
              <li>
                <span class="text-navy-foreground/70">{service}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4
          class="mb-4 text-sm font-bold uppercase tracking-wider text-navy-foreground/50"
        >
          Contacto
        </h4>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-navy-foreground/10 px-3 py-2 text-navy-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
            >
              <MessageCircle size={14} />
              WhatsApp: {clinicBusinessData.whatsappNumber}
            </a>
          </li>
          <li class="flex items-center gap-2 text-navy-foreground/70">
            <Mail size={14} />
            {clinicBusinessData.email}
          </li>
        </ul>
        <div class="mt-4 flex gap-2">
          <a
            href={clinicBusinessData.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg bg-navy-foreground/10 text-navy-foreground/70 transition-all hover:-translate-y-0.5 hover:scale-105 hover:bg-accent hover:text-accent-foreground"
            aria-label="Facebook"
          >
            <Facebook size={16} />
          </a>
          <a
            href={clinicBusinessData.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg bg-navy-foreground/10 text-navy-foreground/70 transition-all hover:-translate-y-0.5 hover:scale-105 hover:bg-accent hover:text-accent-foreground"
            aria-label="Instagram"
          >
            <Instagram size={16} />
          </a>
        </div>
      </div>
    </div>

    <div
      class="mt-12 border-t border-navy-foreground/10 pt-6 text-center text-xs text-navy-foreground/40"
    >
      &copy; {new Date().getFullYear()} Servicios Médicos ROMAT. Todos los derechos
      reservados.
    </div>
  </div>
</footer>
