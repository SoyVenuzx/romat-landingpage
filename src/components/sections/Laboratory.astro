---
import { Image } from 'astro:assets';
import {
  BadgeCheck,
  CalendarCheck2,
  ChevronDown,
  Clock3,
  Dna,
  Droplets,
  FlaskConical,
  type LucideIcon,
  TestTube2,
} from 'lucide-react';
import labLogo from '../../assets/branding/logollab.png';
import laboratoryImage from '../../assets/laboratorio.jpg';

import {
  type LabIcon,
  type LabPromotion,
  labPromotions,
  labServices,
} from '../../data/lab';

const laboratoryWhatsAppNumber = '+505 8681 9616';
const laboratoryWhatsAppMessage =
  'Hola, me gustaría consultar información sobre un examen de laboratorio.';
const laboratoryWhatsAppLink = `https://wa.me/${laboratoryWhatsAppNumber.replace(/\D/g, '')}?text=${encodeURIComponent(laboratoryWhatsAppMessage)}`;
const createPromotionWhatsAppLink = (promotionTitle: string) => {
  const message = `Hola, quisiera más información sobre el paquete o promoción ${promotionTitle}.`;
  return `https://wa.me/${laboratoryWhatsAppNumber.replace(/\D/g, '')}?text=${encodeURIComponent(message)}`;
};

const iconMap: Record<LabIcon, LucideIcon> = {
  Droplets,
  Dna,
  TestTube2,
  FlaskConical,
};

type PromotionWithIndex = {
  promo: LabPromotion & {
    origin: 'clinica' | 'laboratorio' | 'combo';
  };
  index: number;
};

const promotionColumns: [PromotionWithIndex[], PromotionWithIndex[]] = [[], []];

labPromotions.forEach((promo, index) => {
  promotionColumns[index % 2].push({ promo, index });
});

const promotionFilters = [
  { value: 'all', label: 'Todas' },
  { value: 'clinica', label: 'Clínica' },
  { value: 'laboratorio', label: 'Laboratorio' },
  { value: 'combo', label: 'Combo' },
] as const;
---

<section
  id="laboratorio"
  class="section-vivid section-vivid--aqua bg-muted/40 py-16 lg:py-20"
>
  <div class="container mx-auto px-4 lg:px-8">
    <div class="mb-10 text-center lg:mb-12" data-reveal>
      <span
        class="mb-3 inline-block rounded-full border border-accent/30 bg-gradient-to-r from-accent/18 via-secondary/16 to-accent/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-accent shadow-[0_12px_28px_-20px_hsl(var(--accent)/0.65)]"
      >
        Laboratorio clínico
      </span>

      <h2
        class="mb-3 text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl"
      >
        Resultados confiables y rápidos
      </h2>

      <p class="mx-auto max-w-2xl text-muted-foreground">
        Procesos de laboratorio pensados para diagnóstico oportuno, seguimiento
        médico y prevención continua.
      </p>

      <Image
        src={labLogo}
        alt="Logo del laboratorio"
        format="webp"
        width={640}
        height={310}
        loading="lazy"
        class="mx-auto mt-4 h-20 w-auto rounded-xl bg-white px-4 py-2 shadow-[0_12px_32px_-16px_hsl(var(--navy)/0.45)] sm:h-24 lg:h-28"
      />
    </div>

    <div class="grid items-stretch gap-6 lg:grid-cols-2">
      <article
        class="rounded-2xl border border-border bg-card p-5 shadow-card"
        data-reveal
      >
        <header
          class="mb-4 flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:justify-between"
        >
          <h3 class="text-lg font-extrabold text-foreground sm:text-xl">
            Estudios más solicitados
          </h3>
          <span
            class="inline-flex w-fit whitespace-nowrap rounded-full bg-primary/10 px-2.5 py-1 text-center text-[11px] font-bold uppercase tracking-wider text-primary"
          >
            Entrega rápida
          </span>
        </header>

        <div class="grid gap-3 sm:grid-cols-2">
          {
            labServices.map((service, index) => {
              const Icon = iconMap[service.icon];

              return (
                <div
                  class="rounded-xl border border-border bg-background p-4 transition-all hover:-translate-y-0.5 hover:shadow-card"
                  data-reveal
                  data-delay={70 + index * 70}
                >
                  <div class="mb-2 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/15">
                    <Icon size={20} className="text-accent" />
                  </div>
                  <h4 class="text-sm font-bold text-foreground">
                    {service.name}
                  </h4>
                  <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
                    {service.desc}
                  </p>

                  <span class="mt-3 inline-flex items-center gap-1 rounded-md bg-muted px-2 py-1 text-[11px] font-semibold text-muted-foreground">
                    <Clock3 size={12} className="text-primary" />
                    {service.turnaround}
                  </span>
                </div>
              );
            })
          }
        </div>
      </article>

      <article
        class="flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-card"
        data-reveal
        data-delay="120"
      >
        <Image
          src={laboratoryImage}
          alt="Profesional de laboratorio realizando análisis clínico en ROMAT"
          format="webp"
          width={1080}
          height={1080}
          class="h-48 w-full object-cover object-center sm:h-56"
          loading="lazy"
        />

        <div class="flex flex-1 flex-col p-5">
          <h3 class="text-lg font-extrabold text-foreground sm:text-xl">
            Atención de laboratorio con seguimiento médico
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Integramos toma de muestra, análisis y orientación clínica para que
            el paciente entienda sus resultados con claridad.
          </p>

          <ul class="mt-4 space-y-2">
            <li
              class="inline-flex items-start gap-2 text-sm text-muted-foreground"
            >
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"></span>
              Procesos de laboratorio para control y prevención.
            </li>
            <li
              class="inline-flex items-start gap-2 text-sm text-muted-foreground"
            >
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"></span>
              Reportes claros para apoyar decisiones clínicas y seguimiento de tratamientos.
            </li>
          </ul>

          <a
            href={laboratoryWhatsAppLink}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-flex h-11 w-fit items-center justify-center gap-2 rounded-xl bg-accent px-6 text-sm font-bold text-accent-foreground shadow-lg shadow-accent/20 transition-all hover:-translate-y-0.5 hover:bg-accent/90"
          >
            <CalendarCheck2 size={16} />
            Solicitar estudio
          </a>
        </div>
      </article>
    </div>

    <section id="lab-promotions" class="mt-8" data-reveal data-delay="160">
      <div
        class="mb-4 flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:justify-between"
      >
        <div class="flex flex-col items-start gap-2">
          <h3 class="text-xl font-extrabold text-foreground">
            Paquetes y promociones
          </h3>
          <span
            class="inline-flex w-fit items-center rounded-full bg-accent/15 px-2.5 py-1 text-center text-[11px] font-bold uppercase tracking-wider text-accent"
          >
            Clínica, laboratorio y combos
          </span>
        </div>

        <div class="hidden items-center gap-2 md:flex">
          <button
            type="button"
            data-promo-expand-all
            class="inline-flex h-9 items-center justify-center rounded-lg border border-border bg-card px-3 text-xs font-bold text-foreground transition-colors hover:border-primary/35 hover:text-primary"
          >
            Expandir todo
          </button>
          <button
            type="button"
            data-promo-collapse-all
            class="inline-flex h-9 items-center justify-center rounded-lg border border-border bg-card px-3 text-xs font-bold text-foreground transition-colors hover:border-primary/35 hover:text-primary"
          >
            Contraer todo
          </button>
        </div>
      </div>

      <div class="mb-4 flex flex-wrap items-center gap-2" data-promo-filters>
        {
          promotionFilters.map((filter, index) => (
            <button
              type="button"
              data-promo-filter={filter.value}
              aria-pressed={index === 0 ? 'true' : 'false'}
              class={`inline-flex h-9 items-center justify-center rounded-full border px-3.5 text-xs font-bold uppercase tracking-wider transition-colors ${
                index === 0
                  ? 'border-primary/45 bg-primary/12 text-primary'
                  : 'border-border bg-card text-foreground hover:border-primary/35 hover:text-primary'
              }`}
            >
              {filter.label}
            </button>
          ))
        }
      </div>

      <div class="grid gap-4 md:grid-cols-2 md:items-start" data-promo-grid>
        {
          promotionColumns.map((column) => (
            <div class="space-y-4" data-promo-column>
              {
                column.map(({ promo, index }) => (
                  <article
                    data-promo-card
                    data-promo-origin={promo.origin}
                    class="group w-full rounded-2xl border border-border bg-card p-4 shadow-card"
                    data-reveal
                    data-delay={200 + index * 70}
                  >
                    <button
                      type="button"
                      data-promo-trigger
                      aria-expanded="false"
                      aria-controls={`promo-panel-${promo.id}`}
                      class="flex w-full cursor-pointer items-start justify-between gap-3 text-left"
                    >
                      <div>
                        <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-primary">
                          <BadgeCheck size={12} />
                          {promo.badge}
                        </span>
                        <h4 class="mt-2 text-base font-bold text-foreground">
                          {promo.title}
                        </h4>
                        <p class="mt-1 text-sm text-muted-foreground">
                          {promo.summary}
                        </p>
                      </div>

                      <span class="mt-0.5 inline-flex shrink-0 items-center gap-1 text-xs font-bold text-primary">
                        Ver detalles
                        <ChevronDown
                          size={14}
                          data-promo-chevron
                          className="transition-transform duration-300"
                        />
                      </span>
                    </button>

                    <div
                      id={`promo-panel-${promo.id}`}
                      data-promo-panel
                      aria-hidden="true"
                      class="promo-details-panel mt-3"
                      style="height:0px"
                    >
                      <div class="promo-details-inner min-h-0 overflow-hidden border-t border-border/80 pt-3">
                        <ul class="space-y-1.5 text-sm text-muted-foreground">
                          {promo.includes.map((item) => (
                            <li class="flex items-start gap-3 leading-relaxed">
                              <span class="mt-[0.45rem] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />
                              {item}
                            </li>
                          ))}
                        </ul>

                        <p class="mt-3 text-xs font-semibold text-primary">
                          {promo.validity}
                        </p>

                        <a
                          href={createPromotionWhatsAppLink(promo.title)}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="mt-3 inline-flex h-10 items-center justify-center gap-2 rounded-xl bg-accent px-5 text-sm font-bold text-accent-foreground shadow-lg shadow-accent/20 transition-all hover:-translate-y-0.5 hover:bg-accent/90"
                        >
                          <CalendarCheck2 size={16} />
                          Solicitar esta oferta
                        </a>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          ))
        }
      </div>

      <p
        data-promo-empty
        class="mt-4 hidden rounded-xl border border-border bg-card p-3 text-sm text-muted-foreground"
      >
        No hay ofertas disponibles en este filtro por el momento.
      </p>
    </section>
  </div>
</section>

<script is:inline>
  const setupLabPromotions = () => {
    const root = document.getElementById('lab-promotions');
    if (!root) return;

    const cards = Array.from(root.querySelectorAll('[data-promo-card]'));
    if (!cards.length) return;

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;
    const activeFilterClassNames = ['border-primary/45', 'bg-primary/12', 'text-primary'];
    const inactiveFilterClassNames = ['border-border', 'bg-card', 'text-foreground'];

    const promotionGrid = root.querySelector('[data-promo-grid]');
    const filterButtons = Array.from(root.querySelectorAll('[data-promo-filter]'));
    const promotionColumns = Array.from(root.querySelectorAll('[data-promo-column]'));
    const emptyState = root.querySelector('[data-promo-empty]');

    const promoEntries = cards
      .map((card) => {
        const trigger = card.querySelector('[data-promo-trigger]');
        const panel = card.querySelector('[data-promo-panel]');
        const chevron = card.querySelector('[data-promo-chevron]');
        const inner = panel?.firstElementChild;
        const origin = card.dataset.promoOrigin;
        const column = card.closest('[data-promo-column]');

        if (!trigger || !panel || !inner || !origin || !column) {
          return null;
        }

        return { card, trigger, panel, chevron, inner, origin, column };
      })
      .filter(Boolean);

    if (!promoEntries.length) return;

    const setPanelState = (entry, isOpen, instant = false) => {
      entry.trigger.setAttribute('aria-expanded', String(isOpen));
      entry.panel.setAttribute('aria-hidden', String(!isOpen));
      entry.panel.classList.toggle('is-open', isOpen);
      entry.chevron?.classList.toggle('rotate-180', isOpen);

      if (instant || prefersReducedMotion) {
        entry.panel.style.height = isOpen ? 'auto' : '0px';
        return;
      }

      if (isOpen) {
        entry.panel.style.height = '0px';

        requestAnimationFrame(() => {
          entry.panel.style.height = `${entry.inner.scrollHeight}px`;
        });
        return;
      }

      const currentHeight = entry.panel.getBoundingClientRect().height;
      entry.panel.style.height = `${currentHeight}px`;

      requestAnimationFrame(() => {
        entry.panel.style.height = '0px';
      });
    };

    const getVisibleEntries = () =>
      promoEntries.filter((entry) => !entry.card.classList.contains('hidden'));

    const setFilterButtonState = (activeFilter) => {
      filterButtons.forEach((button) => {
        const isActive = button.dataset.promoFilter === activeFilter;
        button.setAttribute('aria-pressed', String(isActive));

        activeFilterClassNames.forEach((className) => {
          button.classList.toggle(className, isActive);
        });

        inactiveFilterClassNames.forEach((className) => {
          button.classList.toggle(className, !isActive);
        });
      });
    };

    const applyFilter = (activeFilter) => {
      let visibleCards = 0;

      promoEntries.forEach((entry) => {
        const isVisible = activeFilter === 'all' || entry.origin === activeFilter;
        entry.card.classList.toggle('hidden', !isVisible);

        if (!isVisible) {
          setPanelState(entry, false, true);
          return;
        }

        visibleCards += 1;
      });

      promotionColumns.forEach((column) => {
        const hasVisibleCards =
          column.querySelector('[data-promo-card]:not(.hidden)') !== null;
        column.classList.toggle('hidden', !hasVisibleCards);
      });

      if (promotionGrid) {
        const visibleColumns = promotionColumns.filter(
          (column) => !column.classList.contains('hidden'),
        ).length;

        const useSingleColumn = visibleColumns <= 1;
        promotionGrid.classList.toggle('md:grid-cols-1', useSingleColumn);
        promotionGrid.classList.toggle('md:grid-cols-2', !useSingleColumn);
      }

      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCards > 0);
      }

      root.dataset.activeFilter = activeFilter;
      setFilterButtonState(activeFilter);
    };

    promoEntries.forEach((entry) => {
      setPanelState(entry, false, true);

      entry.trigger.onclick = () => {
        const isOpen = entry.panel.classList.contains('is-open');
        setPanelState(entry, !isOpen);
      };

      entry.panel.ontransitionend = (event) => {
        if (event.propertyName !== 'height') return;

        if (entry.panel.classList.contains('is-open')) {
          entry.panel.style.height = 'auto';
        }
      };
    });

    const expandAllButton = root.querySelector('[data-promo-expand-all]');
    const collapseAllButton = root.querySelector('[data-promo-collapse-all]');

    if (expandAllButton instanceof HTMLButtonElement) {
      expandAllButton.onclick = () => {
        getVisibleEntries().forEach((entry) => {
          setPanelState(entry, true);
        });
      };
    }

    if (collapseAllButton instanceof HTMLButtonElement) {
      collapseAllButton.onclick = () => {
        getVisibleEntries().forEach((entry) => {
          setPanelState(entry, false);
        });
      };
    }

    filterButtons.forEach((button) => {
      button.onclick = () => {
        const selectedFilter = button.dataset.promoFilter ?? 'all';
        applyFilter(selectedFilter);
      };
    });

    applyFilter(root.dataset.activeFilter ?? 'all');
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupLabPromotions, {
      once: true,
    });
  } else {
    setupLabPromotions();
  }

  document.addEventListener('astro:page-load', setupLabPromotions);
</script>
