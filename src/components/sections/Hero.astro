---
import { Image } from 'astro:assets';
import {
  Activity,
  ArrowRight,
  CalendarCheck2,
  CheckCircle2,
  FlaskConical,
  HeartPulse,
  House,
  MapPin,
  Stethoscope,
} from 'lucide-react';
import clinicFacadeImage from '../../assets/clinica_desde_afuera.jpg';

const trustItems = [
  { icon: House, label: 'Atención médica a domicilio' },
  { icon: Activity, label: 'Ultrasonidos diagnósticos' },
  { icon: FlaskConical, label: 'Servicios de laboratorio' },
  { icon: HeartPulse, label: 'Ecocardiograma' },
  { icon: Stethoscope, label: 'Chequeos médicos ocupacionales' },
];
---

<section
  id="inicio"
  class="relative overflow-hidden bg-gradient-hero pb-12 pt-28 lg:pb-16 lg:pt-36"
>
  <div
    class="pointer-events-none absolute -right-20 -top-28 h-[500px] w-[500px] rounded-full bg-primary/9 blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute -left-24 bottom-0 h-[420px] w-[420px] rounded-full bg-secondary/6 blur-3xl"
  >
  </div>

  <div class="container mx-auto px-4 lg:px-8">
    <div
      class="grid items-center gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:gap-12"
    >
      <div
        class="order-1 flex min-w-0 flex-1 flex-col items-center text-center lg:col-start-1 lg:items-start lg:text-left"
      >
        <span
          class="mb-4 inline-flex animate-fade-up items-center gap-2 rounded-full border bg-white/80 px-4 py-1.5 text-xs font-bold capitalize tracking-wider text-navy shadow-[0_16px_30px_-16px_hsl(var(--navy)/0.36),0_2px_8px_hsl(var(--primary)/0.18)]"
        >
          <MapPin size={14} className="text-primary" />
          Villa Sol, Managua
        </span>

        <h1
          class="max-w-xl text-4xl font-extrabold leading-[1.05] tracking-tight text-foreground motion-safe:opacity-0 motion-safe:animate-fade-up motion-reduce:opacity-100 motion-reduce:animate-none [animation-delay:100ms] sm:text-5xl lg:text-6xl"
        >
          Tu salud, en <span class="text-gradient-primary">manos expertas</span>
        </h1>
      </div>

      <div
        class="order-2 relative flex min-w-0 flex-1 items-center justify-center motion-safe:opacity-0 motion-safe:animate-fade-up motion-reduce:opacity-100 motion-reduce:animate-none [animation-delay:200ms] lg:col-start-2 lg:row-span-2 lg:row-start-1"
      >
        <div
          class="pointer-events-none absolute -inset-4 rounded-[2.6rem] bg-gradient-to-br from-primary/20 via-secondary/10 to-white/50 blur-3xl"
        >
        </div>

        <figure
          class="hero-image-shell relative z-10 aspect-[4/3] w-full max-w-[760px] overflow-hidden rounded-[2rem] border border-border/70 shadow-[0_36px_90px_-40px_hsl(var(--primary)/0.55)] lg:aspect-[7/5]"
        >
          <Image
            src={clinicFacadeImage}
            alt="Fachada de Servicios Médicos ROMAT en Villa Sol, Managua"
            format="webp"
            class="hero-image-media h-full w-full object-cover object-[center_45%]"
            width={961}
            height={720}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            sizes="(max-width: 640px) 95vw, (max-width: 1024px) 88vw, 760px"
          />
        </figure>

        <div
          class="absolute right-3 top-3 z-20 rounded-xl border border-white/55 bg-white/90 px-3 py-1.5 text-[11px] font-semibold text-foreground shadow-card backdrop-blur sm:right-6 sm:top-6"
        >
          <span class="inline-flex items-center gap-1.5">
            <span
              class="inline-block h-2 w-2 rounded-full bg-accent shadow-[0_0_0_4px_hsl(var(--accent)/0.2)]"
            ></span>
            Agenda disponible hoy
          </span>
        </div>

        <div
          class="absolute -left-4 top-10 z-20 hidden animate-float rounded-2xl border border-slate-200/80 bg-white p-2 shadow-card sm:block lg:-left-8"
        >
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/15"
            >
              <CheckCircle2 size={19} className="text-accent" />
            </div>
            <div>
              <p class="text-sm font-bold text-foreground">
                Atención personalizada
              </p>
              <p class="text-xs text-muted-foreground">Para cada paciente</p>
            </div>
          </div>
        </div>

        <div
          class="absolute -right-2 bottom-10 z-20 hidden animate-float rounded-2xl border border-slate-200/80 bg-white p-3 text-right shadow-card [animation-delay:1s] sm:block lg:-right-6"
        >
          <p
            class="text-xl text-center font-extrabold leading-none text-primary"
          >
            +1,000
          </p>
          <p class="mt-1 text-xs font-semibold text-muted-foreground">
            Pacientes atendidos
          </p>
        </div>
      </div>

      <div
        class="order-3 flex min-w-0 flex-1 flex-col items-center text-center lg:col-start-1 lg:row-start-2 lg:items-start lg:text-left"
      >
        <p
          class="mb-7 max-w-lg text-base leading-relaxed text-muted-foreground motion-safe:opacity-0 motion-safe:animate-fade-up motion-reduce:opacity-100 motion-reduce:animate-none [animation-delay:220ms] sm:text-lg"
        >
          En <b>Servicios Médicos ROMAT</b> cuidamos de ti y tu familia en <b
            >Managua y Masaya</b
          >, con especialidades médicas, laboratorio clínico, ultrasonidos y
          atención personalizada. Tu bienestar, cerca de donde estás.
        </p>

        <div
          class="flex flex-col gap-3 motion-safe:opacity-0 motion-safe:animate-fade-up motion-reduce:opacity-100 motion-reduce:animate-none [animation-delay:320ms] sm:flex-row"
        >
          <a
            href="#servicios"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-primary px-4 text-base font-bold text-navy-foreground shadow-[0_16px_34px_-14px_hsl(var(--navy)/0.55)] ring-1 ring-white/55 transition-all hover:-translate-y-0.5 hover:bg-navy/92"
          >
            <ArrowRight size={18} />
            Conoce nuestros servicios
          </a>
          <a
            href="#contacto"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-accent px-8 text-base font-bold text-accent-foreground shadow-[0_16px_34px_-14px_hsl(var(--accent)/0.58)] ring-1 ring-white/45 transition-all hover:-translate-y-0.5 hover:bg-accent/90"
          >
            <CalendarCheck2 size={18} />
            Agenda tu cita
          </a>
        </div>

        <div
          class="mt-6 w-full max-w-2xl motion-safe:opacity-0 motion-safe:animate-fade-up motion-reduce:opacity-100 motion-reduce:animate-none [animation-delay:420ms]"
        >
          <div
            class="flex w-full flex-col gap-2 sm:flex-row sm:flex-wrap sm:justify-center lg:justify-start"
          >
            {
              trustItems.map((item) => (
                <div class="inline-flex w-full items-center justify-start gap-2 rounded-full border border-border/75 bg-card/85 px-3 py-1.5 text-xs font-semibold text-foreground shadow-card sm:w-auto sm:min-w-[220px]">
                  <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10">
                    <item.icon size={14} className="text-primary" />
                  </div>
                  <span class="text-left">{item.label}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
