---
import {
  ArrowRight,
  Calendar,
  CalendarCheck2,
  CheckCircle2,
  FlaskConical,
  ShieldCheck,
} from 'lucide-react';

const trustItems = [
  { icon: ShieldCheck, label: 'Especialistas certificados' },
  { icon: FlaskConical, label: 'Laboratorio propio' },
  { icon: Calendar, label: 'Lunes a sabado' },
];
---

<section
  id="inicio"
  class="relative overflow-hidden bg-gradient-hero pb-10 pt-28 lg:pb-16 lg:pt-36"
>
  <div
    class="pointer-events-none absolute -right-32 -top-32 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute -left-20 bottom-0 h-[400px] w-[400px] rounded-full bg-accent/8 blur-3xl"
  >
  </div>

  <div class="container mx-auto px-4 lg:px-8">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:gap-12">
      <div
        class="flex flex-1 flex-col items-center text-center lg:items-start lg:text-left"
      >
        <span
          class="mb-4 inline-flex animate-fade-up items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-primary"
        >
          <CheckCircle2 size={14} />
          Clinica de confianza
        </span>

        <h1
          class="mb-6 text-4xl font-extrabold leading-[1.1] tracking-tight text-foreground opacity-0 animate-fade-up [animation-delay:100ms] sm:text-5xl lg:text-6xl"
        >
          Tu salud, en <span class="text-gradient-primary">manos expertas</span>
        </h1>

        <p
          class="mb-8 max-w-lg text-lg leading-relaxed text-muted-foreground opacity-0 animate-fade-up [animation-delay:200ms]"
        >
          En Servicios Medicos ROMAT cuidamos de ti y tu familia con atencion
          personalizada, tecnologia de vanguardia y un equipo de especialistas
          comprometidos con tu bienestar.
        </p>

        <div
          class="flex flex-col gap-3 opacity-0 animate-fade-up [animation-delay:300ms] sm:flex-row"
        >
          <a
            href="#servicios"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-primary px-8 text-base font-bold text-primary-foreground shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 hover:bg-primary/90"
          >
            <ArrowRight size={18} />
            Conoce nuestros servicios
          </a>
          <a
            href="#contacto"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-accent px-8 text-base font-bold text-accent-foreground shadow-lg shadow-accent/25 transition-all hover:-translate-y-0.5 hover:bg-accent/90"
          >
            <CalendarCheck2 size={18} />
            Agenda tu cita
          </a>
        </div>

        <div
          class="mt-10 flex flex-wrap items-center justify-center gap-6 opacity-0 animate-fade-up [animation-delay:400ms] lg:justify-start"
        >
          {
            trustItems.map((item) => (
              <div class="flex items-center gap-2">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary/10">
                  <item.icon size={18} className="text-primary" />
                </div>
                <span class="text-sm font-semibold text-foreground">
                  {item.label}
                </span>
              </div>
            ))
          }
        </div>
      </div>

      <div
        class="relative flex flex-1 items-center justify-center opacity-0 animate-fade-up [animation-delay:200ms]"
      >
        <div
          class="absolute h-[340px] w-[340px] rounded-full bg-gradient-to-br from-primary/25 via-secondary/20 to-accent/15 blur-2xl sm:h-[440px] sm:w-[440px]"
        >
        </div>

        <div
          class="relative z-10 h-[340px] w-[300px] overflow-hidden rounded-3xl border border-border bg-card shadow-card sm:h-[440px] sm:w-[360px]"
        >
          <img
            src="/images/clinic/hero-main.svg"
            alt="Especialista medico en atencion clinica ROMAT"
            class="h-full w-full object-cover"
            loading="eager"
          />

          <div
            class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-navy/80 to-transparent p-5 text-left"
          >
            <span
              class="text-xs font-semibold uppercase tracking-wide text-navy-foreground/90"
            >
              Instalaciones modernas
            </span>
            <p class="mt-1 text-sm font-bold text-navy-foreground">
              Atencion profesional y cercana
            </p>
          </div>
        </div>

        <div
          class="absolute -left-4 top-8 z-20 animate-float rounded-2xl bg-card p-4 shadow-card sm:-left-8"
        >
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/15"
            >
              <CheckCircle2 size={20} className="text-accent" />
            </div>
            <div>
              <p class="text-sm font-bold text-foreground">
                Atencion personalizada
              </p>
              <p class="text-xs text-muted-foreground">Para cada paciente</p>
            </div>
          </div>
        </div>

        <div
          class="absolute -right-2 bottom-12 z-20 rounded-2xl bg-card p-4 shadow-card animate-float [animation-delay:1s] sm:-right-6"
        >
          <div class="text-center">
            <p class="text-2xl font-extrabold text-primary">+5,000</p>
            <p class="text-xs font-semibold text-muted-foreground">
              Pacientes atendidos
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
