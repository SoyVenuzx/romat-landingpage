---
import {
  Clock3,
  Facebook,
  Instagram,
  MapPin,
  MessageCircle,
} from 'lucide-react';
import { clinicSchedule } from '../../data/clinic-info';
import { serviceOptions } from '../../data/services';
import { clinicBusinessData } from '../../utils/seo';
import ContactForm from '../islands/ContactForm';
import SectionHeading from '../ui/SectionHeading.astro';

const whatsappLink = `https://wa.me/${clinicBusinessData.whatsappNumber.replace(/\D/g, '')}`;
const mapsEmbedUrl =
  'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4775.14110811362!2d-86.15754390556445!3d12.106097082248313!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8f73f900412e3fdd%3A0x813bc24dea5aa831!2sServicios%20M%C3%A9dicos%20ROMAT!5e0!3m2!1sen!2sus!4v1775534114252!5m2!1sen!2sus';
const mapsExternalUrl =
  'https://www.google.com/maps/search/?api=1&query=12.106097082248313,-86.15754390556445';
---

<section id="contacto" class="py-16 lg:py-20">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="mb-12">
      <SectionHeading
        badge="Contacto"
        badgeColor="accent"
        title="Agenda tu cita por WhatsApp"
        description="Comparte tus datos del paciente y te redirigimos con un mensaje estructurado para recepcion."
      />
    </div>

    <div
      class="grid gap-6 lg:grid-cols-[minmax(0,1.18fr)_minmax(0,0.82fr)] lg:items-start"
    >
      <article
        class="rounded-3xl border border-border bg-card/95 p-5 shadow-card backdrop-blur sm:p-6 lg:p-7"
        data-reveal
      >
        <div class="mb-5">
          <p class="text-xs font-bold uppercase tracking-wider text-primary">
            Formulario de solicitud
          </p>
          <h3
            class="mt-1 text-2xl font-extrabold tracking-tight text-foreground"
          >
            Datos del paciente
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Completa todos los campos obligatorios y envia tu solicitud de forma
            directa a recepcion por WhatsApp.
          </p>
        </div>

        <ContactForm
          client:load
          clinicWhatsApp={clinicBusinessData.whatsappNumber}
          serviceOptions={serviceOptions}
        />
      </article>

      <aside class="space-y-4" data-reveal data-delay="140">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-2xl border border-[hsl(145,78%,40%)]/35 bg-[hsl(145,78%,40%)]/10 p-4 transition-colors hover:bg-[hsl(145,78%,40%)]/16"
        >
          <span
            class="flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(145,78%,40%)]/18 text-[hsl(145,78%,34%)]"
          >
            <MessageCircle size={20} />
          </span>
          <span>
            <span class="block text-sm font-bold text-foreground">WhatsApp</span
            >
            <span class="block text-xs text-muted-foreground"
              >{clinicBusinessData.whatsappNumber}</span
            >
          </span>
        </a>

        <div class="rounded-2xl border border-border bg-card p-4 shadow-card">
          <div class="flex items-start gap-3">
            <span
              class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary"
            >
              <MapPin size={16} />
            </span>
            <div>
              <p class="text-sm font-bold text-foreground">Direccion</p>
              <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
                {clinicBusinessData.address.streetAddress}, {
                  clinicBusinessData.address.addressLocality
                }, {clinicBusinessData.address.addressRegion}, {
                  clinicBusinessData.address.addressCountry
                }
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-border bg-card p-4 shadow-card">
          <div class="flex items-start gap-3">
            <span
              class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary"
            >
              <Clock3 size={16} />
            </span>
            <div>
              <p class="text-sm font-bold text-foreground">
                Horarios de atencion
              </p>
              <p class="mt-1 text-xs text-muted-foreground">
                {clinicSchedule.weekdays}
              </p>
              <p class="text-xs text-muted-foreground">
                {clinicSchedule.weekend}
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-border bg-card p-4 shadow-card">
          <p
            class="mb-3 text-xs font-bold uppercase tracking-wider text-muted-foreground"
          >
            Siguenos
          </p>
          <div class="grid grid-cols-2 gap-2">
            <a
              href={clinicBusinessData.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 items-center justify-center gap-2 rounded-xl border border-border bg-muted/70 text-xs font-bold text-foreground transition-colors hover:border-primary/35 hover:text-primary"
              aria-label="Facebook"
            >
              <Facebook size={14} />
              Facebook
            </a>
            <a
              href={clinicBusinessData.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 items-center justify-center gap-2 rounded-xl border border-border bg-muted/70 text-xs font-bold text-foreground transition-colors hover:border-primary/35 hover:text-primary"
              aria-label="Instagram"
            >
              <Instagram size={14} />
              Instagram
            </a>
          </div>
        </div>

        <div
          class="overflow-hidden rounded-2xl border border-border shadow-card"
        >
          <div
            class="flex items-center justify-between border-b border-border/70 bg-card px-4 py-2.5"
          >
            <p
              class="text-xs font-bold uppercase tracking-wider text-muted-foreground"
            >
              Ubicacion
            </p>
            <a
              href={mapsExternalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-bold text-primary transition-colors hover:text-primary/80"
            >
              Abrir mapa
            </a>
          </div>

          <iframe
            title="Ubicacion Servicios Medicos ROMAT"
            src={mapsEmbedUrl}
            width="100%"
            height="300"
            style="border:0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </aside>
    </div>
  </div>
</section>
