---
import { Clock, Facebook, Instagram, MapPin, MessageCircle, Phone } from 'lucide-react';
import ContactForm from '../islands/ContactForm';
import SectionHeading from '../ui/SectionHeading.astro';
import { serviceOptions } from '../../data/services';
import { clinicSchedule } from '../../data/clinic-info';
import { clinicBusinessData } from '../../utils/seo';

const whatsappLink = `https://wa.me/${clinicBusinessData.whatsappNumber.replace(/\D/g, '')}`;
---

<section id="contacto" class="py-16 lg:py-20">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="mb-12">
      <SectionHeading
        badge="Contacto"
        badgeColor="accent"
        title="Agenda tu cita hoy"
        description="Estamos listos para atenderte. Llena el formulario o contactanos directamente."
      />
    </div>

    <div class="grid gap-10 lg:grid-cols-2">
      <div data-reveal>
        <ContactForm
          client:load
          clinicWhatsApp={clinicBusinessData.whatsappNumber}
          serviceOptions={serviceOptions}
        />

        <div class="space-y-4">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 rounded-xl bg-[hsl(145,78%,40%)]/12 p-4 transition-colors hover:bg-[hsl(145,78%,40%)]/20"
          >
            <MessageCircle size={22} className="text-[hsl(145,78%,40%)]" />
            <div>
              <p class="text-sm font-bold text-foreground">WhatsApp</p>
              <p class="text-xs text-muted-foreground">{clinicBusinessData.whatsappNumber}</p>
            </div>
          </a>

          <div class="flex items-center gap-3 rounded-xl bg-muted p-4">
            <Phone size={20} className="text-primary" />
            <div>
              <p class="text-sm font-bold text-foreground">Telefono</p>
              <p class="text-xs text-muted-foreground">{clinicBusinessData.phone}</p>
            </div>
          </div>

          <div class="flex items-center gap-3 rounded-xl bg-muted p-4">
            <MapPin size={20} className="text-primary" />
            <div>
              <p class="text-sm font-bold text-foreground">Direccion</p>
              <p class="text-xs text-muted-foreground">
                {clinicBusinessData.address.streetAddress}, {clinicBusinessData.address.addressLocality}, {clinicBusinessData.address.addressRegion}, {clinicBusinessData.address.addressCountry}
              </p>
            </div>
          </div>

          <div class="flex items-center gap-3 rounded-xl bg-muted p-4">
            <Clock size={20} className="text-primary" />
            <div>
              <p class="text-sm font-bold text-foreground">Horario</p>
              <p class="text-xs text-muted-foreground">{clinicSchedule.weekdays}</p>
              <p class="text-xs text-muted-foreground">{clinicSchedule.weekend}</p>
            </div>
          </div>

          <div class="flex gap-3 pt-2">
            <a
              href={clinicBusinessData.social.facebook}
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors hover:bg-primary hover:text-primary-foreground"
              aria-label="Facebook"
            >
              <Facebook size={18} />
            </a>
            <a
              href={clinicBusinessData.social.instagram}
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors hover:bg-primary hover:text-primary-foreground"
              aria-label="Instagram"
            >
              <Instagram size={18} />
            </a>
          </div>
        </div>
      </div>

      <div data-reveal data-delay="200">
        <div class="h-full min-h-[400px] overflow-hidden rounded-2xl border border-border shadow-card">
          <iframe
            title="Ubicacion Servicios Medicos ROMAT"
            src="https://www.google.com/maps?q=Villa+Sol,+Sabana+Grande,+Managua,+Nicaragua&output=embed"
            width="100%"
            height="100%"
            style="border:0;min-height:400px"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
