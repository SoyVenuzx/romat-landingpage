---
import SectionHeading from '../ui/SectionHeading.astro';
import ServicesInteractive from '../islands/ServicesInteractive';
import { serviceCategories, servicesByCategory } from '../../data/services';
---

<section id="servicios" class="py-16 lg:py-20">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="mb-12">
      <SectionHeading
        badge="Nuestros servicios"
        title="Cuidado medico integral"
        description="Ofrecemos una amplia gama de servicios medicos con los mas altos estandares de calidad para cuidar de ti y tu familia."
      />
    </div>

    <ServicesInteractive
      client:load
      categories={serviceCategories}
      services={servicesByCategory}
    />
  </div>
</section>
