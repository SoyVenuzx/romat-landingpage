---
import { serviceCategories, servicesByCategory } from "../../data/services";
import ServicesInteractive from "../islands/ServicesInteractive";
import SectionHeading from "../ui/SectionHeading.astro";
---

<section id="servicios" class="section-vivid section-vivid--cool py-16 lg:py-20">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="mb-12">
      <SectionHeading
        badge="Nuestros servicios"
        title="Cuidado médico integral"
        description="Mostramos una selección de servicios destacados por categoría. Si lo necesitas, puedes desplegar el catálogo completo dentro de cada área."
      />
    </div>

    <ServicesInteractive
      client:load
      categories={serviceCategories}
      services={servicesByCategory}
    />

    <p class="mx-auto mt-7 max-w-3xl text-center text-sm leading-relaxed text-muted-foreground">
      Si no encuentras un procedimiento específico, puedes escribirnos por WhatsApp y te ayudamos a
      validar disponibilidad según tu caso clínico.
    </p>
  </div>
</section>
