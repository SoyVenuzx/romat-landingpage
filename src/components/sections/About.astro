---
import { Image } from 'astro:assets';
import { Heart, ShieldCheck } from 'lucide-react';
import consultationRoomImage from '../../assets/consultorio2.jpeg';
import pediatricsRoomImage from '../../assets/pediatria.jpeg';
import receptionImage from '../../assets/recepcion.jpeg';
---

<section id="nosotros" class="section-vivid section-vivid--soft py-16 lg:py-20">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:gap-14">
      <div class="flex-1" data-reveal>
        <span
          class="mb-3 inline-block rounded-full border border-primary/30 bg-gradient-to-r from-primary/16 via-secondary/14 to-primary/8 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-primary shadow-[0_12px_28px_-20px_hsl(var(--primary)/0.65)]"
        >
          Sobre nosotros
        </span>
        <h2 class="mb-6 text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl">
          Una clínica comprometida con tu bienestar
        </h2>
        <p class="mb-4 leading-relaxed text-muted-foreground">
          Desde hace más de 15 años, Servicios Médicos ROMAT ha sido un pilar de salud en nuestra
          comunidad. Nuestro compromiso es ofrecer atención médica de la más alta calidad con un
          trato humano y cercano.
        </p>
        <p class="leading-relaxed text-muted-foreground">
          Contamos con instalaciones modernas, un equipo de especialistas certificados y un
          laboratorio propio que nos permite brindarte diagnósticos rápidos y confiables.
        </p>

        <div class="mt-8 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/15">
            <Heart size={20} className="text-accent" />
          </div>
          <p class="text-sm font-semibold text-foreground">
            "Nuestra mayor satisfacción es la salud de nuestros pacientes"
          </p>
        </div>
      </div>

      <div class="flex-1" data-reveal data-delay="180">
        <div class="grid grid-cols-2 gap-3 sm:gap-4">
          <div class="col-span-2 overflow-hidden rounded-2xl border border-border bg-card shadow-card">
            <Image
              src={consultationRoomImage}
              alt="Consultorio de Servicios Médicos ROMAT"
              format="webp"
              width={1600}
              height={900}
              class="h-56 w-full object-cover sm:h-64"
              loading="lazy"
            />
          </div>

          <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-card">
            <Image
              src={pediatricsRoomImage}
              alt="Área de atención pediátrica en ROMAT"
              format="webp"
              width={1599}
              height={899}
              class="h-36 w-full object-cover sm:h-40"
              loading="lazy"
            />
          </div>

          <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-card">
            <Image
              src={receptionImage}
              alt="Recepción principal de Servicios Médicos ROMAT"
              format="webp"
              width={900}
              height={1600}
              class="h-36 w-full object-cover object-top sm:h-40"
              loading="lazy"
            />
          </div>

          <div class="col-span-2 rounded-2xl border border-border bg-card p-4 shadow-card">
            <div class="inline-flex items-center gap-2 text-sm font-bold text-foreground">
              <ShieldCheck size={16} className="text-primary" />
              Instalaciones equipadas para consulta, diagnóstico y seguimiento integral.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
