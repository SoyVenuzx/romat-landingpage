---
import { Image } from "astro:assets";
import { CalendarClock, CreditCard, HandHeart } from "lucide-react";
import DoctorImage from "../../assets/doctora.jpg";
import {
	clinicSchedule,
	homeConsultation,
	paymentMethods,
} from "../../data/clinic-info";

const highlightCards = [
	{
		icon: CalendarClock,
		title: "Horarios de atención",
		lines: [clinicSchedule.weekdays, clinicSchedule.weekend],
	},
	{
		icon: HandHeart,
		title: homeConsultation.title,
		lines: [homeConsultation.description, homeConsultation.coverage],
	},
	{
		icon: CreditCard,
		title: "Métodos de pago",
		lines: paymentMethods,
	},
];
---

<section class="section-vivid section-vivid--aqua bg-muted/45 py-12 lg:py-14">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="mb-8 text-center lg:mb-9" data-reveal>
        <span
          class="mb-3 inline-block rounded-full border border-primary/30 bg-gradient-to-r from-primary/16 via-secondary/14 to-primary/8 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-primary shadow-[0_12px_28px_-20px_hsl(var(--primary)/0.65)]"
        >
          Por qué elegirnos
        </span>
        <h2
          class="mb-3 text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl"
        >
          Información clave para tu atención
        </h2>
        <p
          class="mx-auto max-w-xl text-sm leading-relaxed text-muted-foreground sm:text-base"
        >
          Organizamos lo esencial para que tengas claridad al momento de agendar
          tu consulta o estudio.
        </p>
      </div>

      <div
        class="grid gap-4 lg:items-start lg:gap-5 lg:grid-cols-[minmax(0,0.9fr)_minmax(360px,430px)]"
      >
        <figure
          class="h-full self-start lg:self-stretch overflow-hidden rounded-2xl border border-border bg-card shadow-card"
          data-reveal
          data-delay="90"
        >
          <Image
            src={DoctorImage}
            alt="Consultorio de Servicios Médicos ROMAT"
            format="webp"
            width={1600}
            height={900}
            class="h-[280px] w-full object-cover object-top sm:h-[340px] lg:h-full"
            loading="lazy"
          />
        </figure>

        <div class="grid gap-3 my-auto">
          {
            highlightCards.map((card, index) => (
              <article
                class="rounded-2xl border border-border bg-card p-5 shadow-card"
                data-reveal
                data-delay={130 + index * 85}
              >
                <div class="flex gap-2 items-center">
                  <div class="mb-2.5 flex h-8 w-8 items-center justify-center rounded-xl bg-accent/15">
                    <card.icon size={20} className="text-accent" />
                  </div>

                  <h3 class="mb-2 text-md font-bold text-foreground">
                    {card.title}
                  </h3>
                </div>

                <ul class="space-y-2">
                  {card.lines.map((line) => (
                    <li class="flex items-start gap-2.5 text-[13px] leading-[1.5] text-muted-foreground sm:text-sm">
                      <span class="mt-[0.5rem] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />
                      {line}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
